# VARIÁVEIS OBRIGATÓRIAS PARA O PAINEL ADMIN (SEGURANÇA)
# A senha que você vai digitar para acessar o seu-site.com/admin
ADMIN_PASSWORD="SuaSenhaForteAqui123"

# Segredo para assinar cookies de sessão e tokens dos links públicos
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# OBRIGATÓRIO em produção (mínimo 16 chars)
SESSION_SECRET="TROQUE-POR-UMA-STRING-ALEATORIA-DE-32-CHARS-OU-MAIS"

# VARIÁVEIS DA EVOLUTION API (CUIDADO COM ERROS DE DIGITAÇÃO)
# URL limpa da sua Evolution (sem barras no final, e sem pontos duplos)
EVO_URL="INSIRA-SUA-URL-EVOLUTION-API"

# Sua Global API Key pegada direto do painel/container da sua API
EVO_GLOBAL_KEY="COLOQUE-SUA-GLOBAL-API-KEY-AQUI"

# CONFIGURAÇÃO DE DOMÍNIO
# Para os links do seu cliente serem gerados corretamente
NEXT_PUBLIC_SITE_URL="https://suaevolutionapi.com.br"
